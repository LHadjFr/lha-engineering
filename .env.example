API_PORT=8787
CONTACT_TO=contact@lha-engineering.fr
RESEND_API_KEY=

# Sender identity used by Resend (must be a verified domain)
# SMTP_FROM=LHA Engineering <contact@lha-engineering.fr>
SMTP_FROM=LHA Engineering <contact@lha-engineering.fr>

# Legacy SMTP vars are no longer used by the API (kept commented for reference)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=

# Anti-spam safeguards
CONTACT_MIN_SUBMIT_TIME_MS=4000
CONTACT_RATE_LIMIT_WINDOW_MS=600000
CONTACT_RATE_LIMIT_MAX=5

# Production deployment
DOMAIN=lha-engineering.fr
LETSENCRYPT_EMAIL=contact@lha-engineering.fr
